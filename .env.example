# Database (Railway PostgreSQL or any Postgres provider)
DATABASE_URL="postgresql://user:password@host:5432/layerup?sslmode=require"

# SendGrid
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="hello@yourdomain.com"
SENDGRID_WEBHOOK_SECRET="your-webhook-signing-secret"

# Vercel Cron authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-32-byte-hex-secret"

# App URL (no trailing slash)
NEXT_PUBLIC_BASE_URL="https://layerup.email"
